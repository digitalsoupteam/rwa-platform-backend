# ==============================================================================
# SECRETS & SENSITIVE DATA
# ==============================================================================

# External API Keys
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=

# Infrastructure Passwords
# ------------------------------------------------------------------------------
# IMPORTANT: Use 'generate-env-values.sh' to create secure strings for production
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_PASSWORD=
GRAFANA_PASSWORD=
LLDAP_ADMIN_PASSWORD=

# JWT & Authentication Secrets
# ------------------------------------------------------------------------------
# Used for signing access and refresh tokens
APP_JWT_SECRET=

# Blockchain Private Keys (KEEP THESE SECRET!)
# ------------------------------------------------------------------------------
# Development: use testnet accounts | Production: use hardware wallet/KMS if possible
BLOCKCHAIN_PROVIDER_URL=
BLOCKCHAIN_CHAIN_ID=97
TESTNET_FAUCET_WALLET_PRIVATE_KEY=
SIGNER_1_PRIVATE_KEY=
SIGNER_2_PRIVATE_KEY=
SIGNER_3_PRIVATE_KEY=

# Smart Contract Addresses (Environment Specific)
# ------------------------------------------------------------------------------
EVENT_EMITTER_ADDRESS=0x57F6d8fbbA21C371d4E594b9399b4ab8eA451d70
HOLD_TOKEN_ADDRESS=0x66670d16331dc923ff095f5b0a658f01e6794216
PLATFORM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000



# ==============================================================================
# 🌍 DEPLOYMENT ENVIRONMENT
# ==============================================================================

# Environment Type (development | production)
DEPLOYMENT_ENVIRONMENT=development

# Domain & Networking
# ------------------------------------------------------------------------------
# dev: rwa.local | prod: api.yourproject.com
BASE_DOMAIN=rwa.local
LLDAP_BASE_DN=dc=rwa,dc=local


# Nginx SSL Configuration
# ----------------------------------------
# Host path to the folder containing certificates
# Local dev: ./nginx/ssl (put fullchain.pem and privkey.pem there)
# Production: /etc/letsencrypt/live/yourdomain.com
NGINX_SSL_PATH=./nginx/ssl

# Host path for Certbot HTTP-01 challenge
# Local dev: ./nginx/challenge
# Production: /var/www/certbot
NGINX_CHALLENGE_PATH=./nginx/challenge


# ==============================================================================
# APPLICATION CONFIGURATIONS
# ==============================================================================

# Infrastructure & Shared Services
# ------------------------------------------------------------------------------
# MongoDB
MONGODB_BASE_URI=mongodb://mongodb:27017

# RabbitMQ
RABBITMQ_RECONNECT_INTERVAL=5000
RABBITMQ_MAX_RECONNECT_ATTEMPTS=10
RABBITMQ_BLOCKCHAIN_EVENTS_EXCHANGE=blockchain.events
RABBITMQ_CHARTS_EXCHANGE=charts.events

# Redis
REDIS_URL=redis://redis:6379

# OpenTelemetry & Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4320
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Monitoring & Logging
PROMETHEUS_RETENTION_TIME=200h
GRAFANA_ALLOW_SIGN_UP=false

# Networking & Proxy
# ------------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# External Service Proxies
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Internal Service URLs (Docker Network)
# ------------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth:3000
RWA_SERVICE_URL=http://rwa:3000
BLOCKCHAIN_SCANNER_SERVICE_URL=http://blockchain-scanner:3000
TESTNET_FAUCET_SERVICE_URL=http://testnet-faucet:3000
ASSISTANT_SERVICE_URL=http://ai-assistant:3000
FILES_SERVICE_URL=http://files:3000
DOCUMENTS_SERVICE_URL=http://documents:3000
GALLERY_SERVICE_URL=http://gallery:3000
QUESTIONS_SERVICE_URL=http://questions:3000
PORTFOLIO_SERVICE_URL=http://portfolio:3000
BLOG_SERVICE_URL=http://blog:3000
FAQ_SERVICE_URL=http://faq:3000
COMPANY_SERVICE_URL=http://company:3000
SIGNERS_MANAGER_SERVICE_URL=http://signers-manager:3000
CHARTS_SERVICE_URL=http://charts:3000
REACTIONS_SERVICE_URL=http://reactions:3000
LOYALTY_SERVICE_URL=http://loyalty:3000
DAO_SERVICE_URL=http://dao:3000
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Core Services
# ------------------------------------------------------------------------------

# Gateway Service
GATEWAY_SERVICE_NAME=gateway
GATEWAY_SERVICE_VERSION=1.0.0
GATEWAY_PORT=3000
# (URLs moved to Internal Service URLs section)

# Auth Service
AUTH_SERVICE_NAME=auth
AUTH_SERVICE_VERSION=1.0.0
AUTH_PORT=3000
AUTH_MONGODB_DBNAME=auth
AUTH_ACCESS_TOKEN_EXPIRY=15m
AUTH_REFRESH_TOKEN_EXPIRY=1d
AUTH_DOMAIN_NAME=RWA Platform
AUTH_DOMAIN_VERSION=1

# RWA Service
RWA_SERVICE_NAME=rwa
RWA_SERVICE_VERSION=1.0.0
RWA_PORT=3000
RWA_MONGODB_DBNAME=rwa

# Blockchain Scanner Service
BLOCKCHAIN_SCANNER_SERVICE_NAME=blockchain-scanner
BLOCKCHAIN_SCANNER_SERVICE_VERSION=1.0.0
BLOCKCHAIN_SCANNER_PORT=3000
BLOCKCHAIN_SCANNER_MONGODB_DBNAME=blockchain-events
BLOCKCHAIN_SCANNER_BLOCK_CONFIRMATIONS=5
